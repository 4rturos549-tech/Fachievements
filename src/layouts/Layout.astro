---
import '../styles/global.css';

interface Props {
  title: string;
  backHref?: string;
  backLabel?: string;
}
const { title, backHref, backLabel } = Astro.props;
---
<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content="Guías y trofeos de videojuegos" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=DM+Sans:ital,opsz,wght@0,9..40,300;0,9..40,400;0,9..40,500;0,9..40,700;1,9..40,300&family=DM+Mono:wght@400;500&display=swap" rel="stylesheet" />
    <style>
      .nav-link { color: #666; font-size: 0.75rem; font-weight: 600; letter-spacing: 0.08em; text-transform: uppercase; text-decoration: none; transition: color 0.2s; display: flex; align-items: center; gap: 6px; }
      .nav-link:hover { color: #f0ece4; }
      .nav-back { color: #555; font-size: 0.72rem; font-weight: 600; letter-spacing: 0.08em; text-transform: uppercase; text-decoration: none; transition: color 0.2s; display: flex; align-items: center; gap: 6px; }
      .nav-back:hover { color: #f5a623; }
      .nav-profile { display:flex; align-items:center; gap:6px; background:#111; border:1px solid #2a2a2a; color:#f0ece4; font-size:0.72rem; font-weight:600; letter-spacing:0.08em; text-transform:uppercase; padding:0.45rem 1rem; border-radius:6px; text-decoration:none; transition:border-color 0.2s, color 0.2s; }
      .nav-profile:hover { border-color: #f5a623; color: #f5a623; }
      .nav-logo { font-family:'Bebas Neue',sans-serif; font-size:1.35rem; letter-spacing:0.1em; color:#f5a623; text-decoration:none; }
      .nav-logo-small { font-family:'Bebas Neue',sans-serif; font-size:1.1rem; letter-spacing:0.1em; color:#f5a623; text-decoration:none; opacity:0.6; transition:opacity 0.2s; }
      .nav-logo-small:hover { opacity:1; }
    </style>
  </head>
  <body style="background:#080808; color:#f0ece4; font-family:'DM Sans',sans-serif; min-height:100vh; font-weight:300;">

    <nav style="position:sticky; top:0; z-index:100; background:rgba(8,8,8,0.94); border-bottom:1px solid #1e1e1e; backdrop-filter:blur(16px); -webkit-backdrop-filter:blur(16px);">
      <div style="max-width:1100px; margin:0 auto; padding:0 1.5rem; height:54px; display:flex; align-items:center; justify-content:space-between;">

        <div style="display:flex; align-items:center; gap:1.5rem;">
          {backHref ? (
            <a href={backHref} class="nav-back">
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M19 12H5M12 19l-7-7 7-7"/></svg>
              {backLabel || 'Volver'}
            </a>
          ) : (
            <a href="/" class="nav-logo">Fachievements</a>
          )}
        </div>

        <div style="display:flex; align-items:center; gap:1.25rem;">
          {backHref && (
            <a href="/" class="nav-logo-small">Fachievements</a>
          )}
          <a href="/perfil" class="nav-profile">
            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
            Perfil
          </a>
        </div>

      </div>
    </nav>

    <slot />

  </body>
</html>
