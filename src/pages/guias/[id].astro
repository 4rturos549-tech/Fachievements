---
export const prerender = false;
import Layout from '../../layouts/Layout.astro';
import App from '../../components/App.tsx';
import { getGameMetadata } from '../../lib/igdb';
import { createClient } from '@supabase/supabase-js';

const { id } = Astro.params;
if (!id) return Astro.redirect('/');

let manifest = null;

// 1. Buscar en Supabase primero
try {
  const supabase = createClient(
    process.env.PUBLIC_SUPABASE_URL!,
    process.env.PUBLIC_SUPABASE_ANON_KEY!
  );
  const { data } = await supabase
    .from('game_guides')
    .select('manifest')
    .eq('igdb_id', String(id))
    .single();

  if (data?.manifest) manifest = data.manifest;
} catch (e) {}

// 2. Si no está en Supabase, buscar en archivos locales
if (!manifest) {
  try {
    const allGuides = import.meta.glob('../../data/*.json', { eager: true });
    for (const path in allGuides) {
      const module: any = allGuides[path];
      const data = module.default ?? module;
      if (String(data.igdb_id) === String(id)) {
        manifest = data;
        break;
      }
    }
  } catch (e) {}
}

const meta = await getGameMetadata(id);
if (!meta) return Astro.redirect('/');
---

<Layout title={`${meta.name} — Fachievements`} backHref="/" backLabel="Buscador">

  <div style="position:relative; border-bottom:1px solid #1e1e1e; overflow:hidden;">
    {(meta.screenshots?.[0] || meta.coverUrl) && (
      <div style="position:absolute; inset:0; overflow:hidden;">
        <img src={meta.screenshots?.[0] || meta.coverUrl} alt="" style="width:100%; height:100%; object-fit:cover; filter:blur(24px) saturate(0.4); opacity:0.12; transform:scale(1.1);" />
        <div style="position:absolute; inset:0; background:linear-gradient(to bottom, transparent 0%, #080808 85%);"></div>
      </div>
    )}
    <div style="position:relative; z-index:1; max-width:1100px; margin:0 auto; padding:2.5rem 1.5rem 3rem; display:flex; gap:2rem; align-items:flex-end; flex-wrap:wrap;">
      {meta.coverUrl && (
        <img src={meta.coverUrl} alt={meta.name} style="width:120px; border-radius:8px; box-shadow:0 16px 48px rgba(0,0,0,0.7); border:1px solid #2a2a2a; flex-shrink:0;" />
      )}
      <div style="flex:1; min-width:0;">
        <h1 style="font-family:'Bebas Neue',sans-serif; font-size:clamp(2rem,5vw,3.5rem); letter-spacing:0.04em; line-height:1; color:#f0ece4; margin-bottom:1rem;">{meta.name}</h1>
        <div style="display:flex; flex-wrap:wrap; gap:0.5rem; align-items:center;">
          <span style="font-size:0.72rem; font-weight:600; letter-spacing:0.08em; text-transform:uppercase; color:#555; background:#111; border:1px solid #222; padding:4px 10px; border-radius:5px; display:flex; align-items:center; gap:5px;">
            <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
            {meta.releaseDate}
          </span>
          {meta.rating && (
            <span style="font-size:0.72rem; font-weight:700; letter-spacing:0.08em; text-transform:uppercase; color:#f5a623; background:rgba(245,166,35,0.1); border:1px solid rgba(245,166,35,0.25); padding:4px 10px; border-radius:5px; display:flex; align-items:center; gap:5px;">
              <svg width="11" height="11" viewBox="0 0 24 24" fill="#f5a623" stroke="none"><polygon points="12,2 15.09,8.26 22,9.27 17,14.14 18.18,21.02 12,17.77 5.82,21.02 7,14.14 2,9.27 8.91,8.26"/></svg>
              {meta.rating}/100
            </span>
          )}
          <span style="font-size:0.72rem; font-weight:500; color:#444; max-width:400px; white-space:nowrap; overflow:hidden; text-overflow:ellipsis;">
            {meta.platforms}
          </span>
        </div>
      </div>
    </div>
  </div>

  <main style="max-width:900px; margin:0 auto; padding:2rem 1.5rem 6rem;">
    <App manifest={manifest} meta={meta} client:load />
  </main>

</Layout>
